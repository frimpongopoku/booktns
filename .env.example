# Environment variables declared in this file are NOT automatically loaded by Prisma —
# prisma.config.ts loads them via `dotenv/config`.

# Local Postgres — pick your own values (e.g. `openssl rand -base64 18` for the
# password), then `docker compose up -d`. docker-compose.yml reads the three
# POSTGRES_* vars directly; DATABASE_URL must encode the same values.
POSTGRES_USER="booktns"
POSTGRES_PASSWORD="change-me"
POSTGRES_DB="booktns_dev"
DATABASE_URL="postgresql://booktns:change-me@localhost:5434/booktns_dev?schema=public"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Firebase client config (safe to expose) — Firebase console → Project settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Firebase Admin SDK (server-only, secret) — Project settings → Service accounts → Generate new private key
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Session JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=
